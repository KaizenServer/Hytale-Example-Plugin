        Label #NodeLvlReq { Style: (TextColor: #ffaa44(0.9), FontSize: 9); Anchor: (Height: 12); Text: ""; }
        Button #NodeBtn {
          Anchor: (Width: 144, Height: 26);
          Style: (Default: (Background: #00000000), Hovered: (Background: #ffffff(0.08)), Pressed: (Background: #ffffff(0.12)));
