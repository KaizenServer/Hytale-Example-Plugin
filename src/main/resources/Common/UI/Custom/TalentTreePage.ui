// CombatPlugin — Talent Tree Page
// cmd.append("TalentTreePage.ui") inlines this file's content directly.
// IMPORTANT: All IDs must be globally unique — Hytale has no descendant selector support.
// Selectors in Java must be flat: "#N0Name", not "#Node0 #NodeName".
// 16 nodes in a 5-tier layout. NodeW=160 NodeH=80 NodeGap=12

Group {
  Background: #000000(0.60);
  LayoutMode: Middle;

  Group {
    Anchor: (Width: 728, Height: 488);
    LayoutMode: Top;
    Background: #0d0d1a(0.95);
    Padding: (Full: 16);

    // Header row
    Group {
      Anchor: (Height: 32);
      LayoutMode: Left;

      Label #PageClass {
        Style: (RenderBold: true, FontSize: 16);
        Anchor: (Width: 400, Height: 32);
        Text: "Talent Tree";
      }

      Label #PagePoints {
        Style: (TextColor: #88ff88(1.0), FontSize: 12);
        Anchor: (Height: 32);
        Text: "Points: 0";
      }
    }

    // Row 0 — T0 root (1 node)
    Group {
      Anchor: (Height: 92);
      LayoutMode: Left;

      Group #Node0 {
        Anchor: (Width: 160, Height: 80);
        LayoutMode: Top;
        Background: #1e1e3a(0.92);
        Padding: (Full: 8);

        Label #N0Name {
          Style: (RenderBold: true, FontSize: 11);
          Anchor: (Height: 18);
          Text: "";
        }
        Label #N0Rank {
          Style: (TextColor: #88ddff(1.0), FontSize: 10);
          Anchor: (Height: 14);
          Text: "0/1";
        }
        Label #N0LvlReq {
          Style: (TextColor: #ffaa44(0.9), FontSize: 9);
          Anchor: (Height: 12);
          Text: "";
        }
        Button #N0Btn {
          Anchor: (Width: 144, Height: 26);
          Style: (
            Default: (Background: #00000000),
            Hovered: (Background: #ffffff(0.08)),
            Pressed: (Background: #ffffff(0.12))
          );
        }
      }
    }

    // Row 1 — T1 (3 nodes)
    Group {
      Anchor: (Height: 92);
      LayoutMode: Left;

      Group #Node1 {
        Anchor: (Width: 160, Height: 80);
        LayoutMode: Top;
        Background: #1e1e3a(0.92);
        Padding: (Full: 8);
        Label #N1Name { Style: (RenderBold: true, FontSize: 11); Anchor: (Height: 18); Text: ""; }
        Label #N1Rank { Style: (TextColor: #88ddff(1.0), FontSize: 10); Anchor: (Height: 14); Text: "0/1"; }
        Label #N1LvlReq { Style: (TextColor: #ffaa44(0.9), FontSize: 9); Anchor: (Height: 12); Text: ""; }
        Button #N1Btn { Anchor: (Width: 144, Height: 26); Style: (Default: (Background: #00000000), Hovered: (Background: #ffffff(0.08)), Pressed: (Background: #ffffff(0.12))); }
      }

      Group { Anchor: (Width: 12); }

      Group #Node2 {
